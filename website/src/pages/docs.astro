---
import Base from '../layouts/Base.astro';
import helpData from '../../../vireo/static/help.json';

const base = import.meta.env.BASE_URL;

// Group help entries by category, preserving insertion order
const grouped: Record<string, typeof helpData> = {};
for (const entry of helpData) {
  const cat = entry.category || 'Other';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(entry);
}
---

<Base title="Docs — Vireo" description="Getting started with Vireo and FAQ.">

  <section class="section section--dark docs-header">
    <div class="container">
      <h1>Documentation</h1>
      <p class="docs-header__subtitle">Everything you need to get started with Vireo.</p>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="section" id="getting-started">
    <div class="container docs-section">
      <h2>Getting Started</h2>

      <div class="docs-step">
        <h3>1. Install Vireo</h3>
        <p>Download the installer for your platform from the <a href={`${base}download/`}>download page</a> and run it. On macOS, drag Vireo to your Applications folder. On Windows, run the setup wizard. On Linux, install the .deb package.</p>
      </div>

      <div class="docs-step">
        <h3>2. Add your photo folders</h3>
        <p>Open Vireo and click <strong>Add Folder</strong> in the sidebar. Navigate to any directory containing your wildlife photos. Vireo reads your files in place — nothing is moved or copied. You can add multiple folders.</p>
      </div>

      <div class="docs-step">
        <h3>3. Run your first scan</h3>
        <p>Click <strong>Scan</strong> to start the classification pipeline. Vireo will detect subjects, classify species, and score quality for every photo. Progress streams in real time — you can watch the log panel for details. First runs download models (~500 MB), so give it a few minutes.</p>
      </div>

      <div class="docs-step">
        <h3>4. Review results</h3>
        <p>Once the scan completes, every photo has a label: <strong>keep</strong>, <strong>review</strong>, or <strong>reject</strong>. Open the <strong>Cull</strong> page to rapidly sort through them. Use keyboard shortcuts to move through photos and make decisions.</p>
      </div>

      <div class="docs-step">
        <h3>5. Sync to XMP</h3>
        <p>When you're happy with your decisions, sync changes to XMP sidecars. This writes standard metadata that Lightroom, Darktable, and other tools can read. Your decisions travel with your files.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--light" id="faq">
    <div class="container docs-section">
      <h2>FAQ</h2>

      <div class="faq-search">
        <input type="text" id="faqSearchInput" placeholder="Search help topics..." autocomplete="off" />
      </div>

      <div id="faqNoResults" class="faq-no-results" style="display:none;">
        No results found. Try different keywords.
      </div>

      <div id="faqEntries">
        {Object.entries(grouped).map(([category, entries]) => (
          <div class="faq-group" data-category={category}>
            <div class="faq-category-heading">{category}</div>
            {entries.map((entry) => (
              <div class="faq-item" data-question={entry.question} data-keywords={entry.keywords.join(',')} data-answer={entry.answer} data-cat={entry.category}>
                <h3>{entry.question}</h3>
                <span class="faq-badge">{entry.category}</span>
                <p>{entry.answer}</p>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub Callout -->
  <section class="section section--navy">
    <div class="container github-callout">
      <h2>Looking for more?</h2>
      <p>For technical documentation, troubleshooting, API details, and contributing guidelines, visit the project on GitHub.</p>
      <a href="https://github.com/jss367/vireo" class="btn btn--primary btn--large" target="_blank" rel="noopener">View on GitHub</a>
    </div>
  </section>

</Base>

<style>
  .docs-header {
    text-align: center;
    padding-bottom: var(--space-3xl);
  }

  .docs-header h1 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  .docs-header__subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
  }

  /* Docs sections */
  .docs-section h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2xl);
  }

  /* Getting Started steps */
  .docs-step {
    margin-bottom: var(--space-xl);
  }

  .docs-step h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .docs-step p {
    color: var(--color-text-muted);
    max-width: 700px;
  }

  /* FAQ search */
  .faq-search {
    margin-bottom: var(--space-2xl);
  }

  .faq-search input {
    width: 100%;
    max-width: 500px;
    padding: 12px 16px;
    font-size: var(--text-base);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    background: #fff;
    color: var(--color-text);
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .faq-search input:focus {
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .faq-search input::placeholder {
    color: var(--color-text-muted);
  }

  /* FAQ category headings */
  .faq-category-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .faq-group:first-child .faq-category-heading {
    margin-top: 0;
  }

  .faq-badge {
    display: inline-block;
    font-size: var(--text-xs, 0.75rem);
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.05);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs, 0.25rem);
  }

  .faq-no-results {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-3xl) 0;
    font-size: var(--text-base);
  }

  /* FAQ items */
  .faq-item {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .faq-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .faq-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .faq-item p {
    color: var(--color-text-muted);
    max-width: 700px;
  }

  .faq-item code {
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  /* Hidden state for search filtering */
  .faq-item.hidden,
  .faq-group.hidden {
    display: none;
  }

  /* GitHub callout */
  .github-callout {
    text-align: center;
  }

  .github-callout h2 {
    font-size: var(--text-3xl);
    color: var(--color-warm-white);
    margin-bottom: var(--space-md);
  }

  .github-callout p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
</style>

<script>
  import Fuse from 'fuse.js';

  const items = Array.from(document.querySelectorAll('.faq-item')).map(el => ({
    question: el.getAttribute('data-question') || '',
    keywords: (el.getAttribute('data-keywords') || '').split(','),
    answer: el.getAttribute('data-answer') || '',
    category: el.getAttribute('data-cat') || ''
  }));

  const fuse = new Fuse(items, {
    keys: [
      { name: 'question', weight: 3 },
      { name: 'keywords', weight: 2 },
      { name: 'answer', weight: 1 }
    ],
    threshold: 0.4,
    includeMatches: true
  });

  const input = document.getElementById('faqSearchInput') as HTMLInputElement;
  const entriesContainer = document.getElementById('faqEntries')!;
  const noResults = document.getElementById('faqNoResults')!;
  const allItems = entriesContainer.querySelectorAll<HTMLElement>('.faq-item');
  const allGroups = entriesContainer.querySelectorAll<HTMLElement>('.faq-group');

  function showAll() {
    allItems.forEach(el => el.classList.remove('hidden'));
    allGroups.forEach(el => el.classList.remove('hidden'));
    // Restore category headings visibility
    entriesContainer.querySelectorAll<HTMLElement>('.faq-category-heading').forEach(el => {
      el.style.display = '';
    });
    noResults.style.display = 'none';
  }

  function filterBySearch(query: string) {
    if (!query.trim()) {
      showAll();
      return;
    }

    const hits = fuse.search(query);

    if (hits.length === 0) {
      allItems.forEach(el => el.classList.add('hidden'));
      allGroups.forEach(el => el.classList.add('hidden'));
      noResults.style.display = '';
      return;
    }

    noResults.style.display = 'none';

    // Build set of matching questions
    const matchingQuestions = new Set(hits.map(h => h.item.question));

    // Hide category headings during search (results shown flat)
    entriesContainer.querySelectorAll<HTMLElement>('.faq-category-heading').forEach(el => {
      el.style.display = 'none';
    });

    // Show/hide individual items
    allItems.forEach(el => {
      const q = el.getAttribute('data-question');
      if (q && matchingQuestions.has(q)) {
        el.classList.remove('hidden');
      } else {
        el.classList.add('hidden');
      }
    });

    // Show all groups (items inside handle their own visibility)
    allGroups.forEach(el => el.classList.remove('hidden'));
  }

  input.addEventListener('input', () => filterBySearch(input.value));
</script>
