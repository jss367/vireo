---
interface Props {
  platform: 'macos' | 'windows' | 'linux';
  label: string;
  href: string;
  version: string;
  highlighted?: boolean;
}

const { platform, label, href, version, highlighted = false } = Astro.props;

const platformNames: Record<string, string> = {
  macos: 'macOS',
  windows: 'Windows',
  linux: 'Linux',
};
---

<a
  href={href}
  class:list={['download-btn', { 'download-btn--highlighted': highlighted }]}
  data-platform={platform}
>
  <svg class="download-btn__icon" viewBox="0 0 24 24" width="32" height="32" fill="currentColor" aria-hidden="true">
    {platform === 'macos' && (
      <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
    )}
    {platform === 'windows' && (
      <path d="M3 12V6.5l8-1.1V12H3zm0 .5V18l8 1.1V12.5H3zM11.5 4.85L22 3v9.5H11.5V4.85zM22 12.5V21l-10.5-1.65V12.5H22z" />
    )}
    {platform === 'linux' && (
      <path d="M20.581 19.049c-.55-.446-.336-1.431-.907-1.917.553-3.365-.997-6.331-2.845-8.232-1.551-1.595-1.051-3.147-1.051-4.49 0-2.146-.881-4.41-3.55-4.41-2.853 0-3.635 2.38-3.663 3.738-.02 1.002.489 2.76-1.066 4.942-1.79 2.512-2.717 4.674-2.217 8.03-.575.478-.34 1.474-.907 1.917-.508.396-.588 1.489.22 1.843.742.326 1.657.378 2.26-.393.076-.098.392-.665.7-.899.324-.246.682-.092 1.03.047.474.19.968.395 1.663.443.727.05 1.178-.207 1.626-.462.35-.2.697-.398 1.159-.398s.809.198 1.16.398c.447.255.898.512 1.625.462.695-.048 1.19-.253 1.663-.443.348-.14.706-.293 1.03-.047.307.234.624.801.699.899.604.771 1.518.719 2.26.393.808-.354.728-1.447.22-1.843zm-8.58-1.189c-1.047 0-1.965-.554-2.485-1.378.39-.317.8-.614 1.293-.705.47-.086.93.16 1.192.422.262-.262.722-.508 1.192-.422.493.091.903.388 1.293.705-.52.824-1.438 1.378-2.485 1.378z" />
    )}
  </svg>
  <span class="download-btn__info">
    <span class="download-btn__label">{label}</span>
    <span class="download-btn__meta">{platformNames[platform]} &middot; v{version}</span>
  </span>
</a>

<style>
  .download-btn {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    color: var(--color-warm-white);
    transition: all var(--transition-base);
    min-width: 220px;
  }

  .download-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--color-accent);
    color: var(--color-warm-white);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .download-btn--highlighted {
    border-color: var(--color-accent);
    background: rgba(212, 168, 0, 0.1);
  }

  .download-btn__icon {
    flex-shrink: 0;
  }

  .download-btn__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .download-btn__label {
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .download-btn__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
