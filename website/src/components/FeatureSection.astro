---
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  reverse?: boolean;
}

const { title, description, image, imageAlt, reverse = false } = Astro.props;
---

<div class:list={['feature', { 'feature--reverse': reverse }]}>
  <div class="feature__image">
    <img src={image} alt={imageAlt} class="screenshot" />
  </div>
  <div class="feature__text">
    <h3 class="feature__title">{title}</h3>
    <p class="feature__description">{description}</p>
  </div>
</div>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
    padding: var(--space-3xl) 0;
  }

  .feature--reverse {
    direction: rtl;
  }

  .feature--reverse > * {
    direction: ltr;
  }

  .feature__image img {
    width: 100%;
    max-width: 520px;
  }

  .feature__title {
    font-size: var(--text-3xl);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-md);
    color: var(--color-text-on-light);
  }

  .feature__description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 480px;
  }

  @media (max-width: 768px) {
    .feature {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      text-align: center;
    }

    .feature--reverse {
      direction: ltr;
    }

    .feature__image img {
      max-width: 100%;
      margin: 0 auto;
    }

    .feature__description {
      max-width: 100%;
      margin: 0 auto;
    }
  }
</style>
